# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dynamic_bridge

# Ollama (local LLM — no API costs)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream

# OpenAI API (reserved for future use)
OPENAI_API_KEY=

# Anthropic API (reserved for future use)
ANTHROPIC_API_KEY=

# Supabase (optional, for realtime features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Playwright
PLAYWRIGHT_HEADLESS=true
